{
  "version": 4,
  "configurations": [
    {
      "name": "Linux",
      "compilerPath": "/usr/bin/gcc",
      "cStandard": "c99",
      "cppStandard": "c++17",
      "intelliSenseMode": "linux-gcc-x64",
      "includePath": [
        "${workspaceFolder}",
        "${workspaceFolder}/src",
        "${workspaceFolder}/lib/src/raylib-5.5/src",
        "${workspaceFolder}/lib/src/raygui-4.0/src",
        "/usr/local/include"
      ],
      "defines": [
        "_DEFAULT_SOURCE",
        "PLATFORM_DESKTOP"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}/src"
        ],
        // "limitSymbolsToIncludedHeaders": true
      }
    }
  ]
}